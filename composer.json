{
    "name": "globyapp/odata-to-doctrine",
    "description": "Symfony plugin to use odata-query-parser to create a doctrine QueryBuilder for any annotated DTO and execute it.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Globyapp\\OdataToDoctrine\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Justin Ruiter",
            "email": "globy@justinruiter.nl"
        }
    ],
    "minimum-stability": "stable",
    "require-dev": {
        "phpunit/phpunit": "13.*",
        "friendsofphp/php-cs-fixer": "3.*",
        "phpstan/phpstan": "2.*",
        "phpstan/phpstan-deprecation-rules": "2.*",
        "vimeo/psalm": "6.*",
        "infection/infection": "0.*"
    },
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "require": {
        "php": ">=8.3 <8.6",
        "doctrine/orm": "3.*",
        "doctrine/persistence": "4.*",
        "globyapp/odata-query-parser": "^1.2",
        "symfony/validator": "^7",
        "symfony/http-foundation": "^7",
        "doctrine/doctrine-bundle": "3.*",
        "symfony/serializer-pack": "1.*"
    }
}
